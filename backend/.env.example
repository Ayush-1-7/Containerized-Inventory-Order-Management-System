# ---- Backend configuration (copy to .env and adjust) ----

# Full SQLAlchemy database URL.
# Local Docker Compose uses the service name "db" as host.
DATABASE_URL=postgresql+psycopg2://ioms:ioms_password@db:5432/ioms

# Comma-separated list of allowed CORS origins (your frontend URLs).
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:8080

# Products at or below this stock level are flagged "low stock".
LOW_STOCK_THRESHOLD=10

# Set to "true" to load demo data automatically on startup.
SEED_ON_STARTUP=true

# Server
PORT=8000
WEB_CONCURRENCY=2
ENVIRONMENT=development
