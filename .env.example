# ============================================================
#  Root environment for Docker Compose. Copy to `.env`:
#     cp .env.example .env
#  NEVER commit your real .env file.
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=ioms
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ioms
POSTGRES_PORT=5432

# ---- Backend ----
BACKEND_PORT=8000
LOW_STOCK_THRESHOLD=10
SEED_ON_STARTUP=true
WEB_CONCURRENCY=2
# Origins allowed by CORS — must include the frontend's public URL.
FRONTEND_ORIGIN=http://localhost:8080,http://localhost:5173

# ---- Frontend ----
FRONTEND_PORT=8080
# Where the browser reaches the backend. For local Compose this is the
# host-published backend port (NOT the internal docker hostname).
VITE_API_BASE_URL=http://localhost:8000
